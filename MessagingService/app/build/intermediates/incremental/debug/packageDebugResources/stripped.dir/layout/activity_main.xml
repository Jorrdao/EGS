<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FAFAFA">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Messaging Service"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Online (REST/JSON) + Offline (BLE/ProtoBuf)"
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginBottom="16dp" />

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:background="#E3F2FD"
        android:textColor="#0D47A1"
        android:textSize="14sp"
        android:text="Service not started"
        android:layout_marginBottom="12dp" />

    <!-- Control buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnStartService"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start Service"
            android:backgroundTint="#1976D2"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnStopService"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Stop Service"
            android:backgroundTint="#D32F2F"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <Button
        android:id="@+id/btnSendTest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send Test Online Message"
        android:backgroundTint="#388E3C"
        android:layout_marginBottom="16dp" />

    <!-- KPI panel -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="KPI Metrics (refreshes every 3s)"
        android:textStyle="bold"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#ECEFF1"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvKpi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="#212121" />

    </ScrollView>

    <!-- Event log -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Event Log"
        android:textStyle="bold"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#212121">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="#69FF47" />

    </ScrollView>

</LinearLayout>
